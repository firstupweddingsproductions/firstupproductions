---
import { detectLang, routes, type Lang } from '../i18n/routes';
import { t } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const currentPath = Astro.url.pathname;
const { lang = detectLang(currentPath) } = Astro.props;
const currentYear = new Date().getFullYear();

const navItems = [
  { href: routes[lang].angebot, label: t(lang, 'nav.angebot') },
  { href: routes[lang].arbeitsweise, label: t(lang, 'nav.arbeitsweise') },
  { href: routes[lang]['ueber-mich'], label: t(lang, 'nav.ueber-mich') },
  { href: routes[lang].kontakt, label: t(lang, 'nav.kontakt') },
];
---
<footer class="bg-brand-dark border-t border-white/5">
  <div class="px-6 md:px-12 lg:px-24 py-16">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">

      <!-- Brand -->
      <div>
        <a href={routes[lang].home}>
          <span class="font-heading text-base font-semibold tracking-wider uppercase text-brand-light">First Up Productions</span>
        </a>
        <p class="mt-4 text-sm text-brand-muted leading-relaxed">
          {t(lang, 'footer.tagline')}
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-xs uppercase tracking-widest text-brand-muted mb-4">{t(lang, 'footer.nav-heading')}</h4>
        <ul class="space-y-2 text-sm">
          {navItems.map(item => (
            <li><a href={item.href} class="text-brand-light/70 hover:text-brand-accent transition-colors">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Kontakt -->
      <div>
        <h4 class="text-xs uppercase tracking-widest text-brand-muted mb-4">{t(lang, 'footer.contact-heading')}</h4>
        <ul class="space-y-2 text-sm text-brand-light/70">
          <li><a href="mailto:firstupproductions.media@gmail.com" class="hover:text-brand-accent transition-colors">firstupproductions.media@gmail.com</a></li>
          <li><a href="tel:+491732118910" class="hover:text-brand-accent transition-colors">+49 173 2118910</a></li>
          <li>{t(lang, 'footer.location')}</li>
        </ul>
      </div>

      <!-- Legal + Social -->
      <div>
        <h4 class="text-xs uppercase tracking-widest text-brand-muted mb-4">{t(lang, 'footer.legal-heading')}</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={routes[lang].impressum} class="text-brand-light/70 hover:text-brand-accent transition-colors">{t(lang, 'footer.legal-imprint')}</a></li>
          <li><a href={routes[lang].datenschutz} class="text-brand-light/70 hover:text-brand-accent transition-colors">{t(lang, 'footer.legal-privacy')}</a></li>
        </ul>
        <div class="mt-6 flex gap-4">
          <a href="https://www.instagram.com/firstupproductions/" target="_blank" rel="noopener noreferrer" class="text-brand-muted hover:text-brand-accent transition-colors" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <span class="text-brand-muted" aria-label="Vimeo">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.875 10.063c-2.442 5.217-8.337 12.319-12.063 12.319-3.672 0-4.203-7.831-6.208-13.043-.961-2.502-1.577-1.932-3.188-.649l-1.416-1.837c3.261-2.864 6.521-6.188 8.531-6.375 2.25-.211 3.636 1.322 4.157 4.599.563 3.543 1.339 9.063 2.719 9.063 1.063 0 3.672-4.344 3.797-5.906.219-2.344-1.725-2.422-3.422-1.688 2.461-8.063 12.758-6.563 6.093 3.517z"/></svg>
          </span>
          <a href="https://www.tiktok.com/@first.up.productions?_r=1&_t=ZG-96EKANmE53Y" target="_blank" rel="noopener noreferrer" class="text-brand-muted hover:text-brand-accent transition-colors" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="-2 -2 28 28"><path d="M12.53.02C13.84 0 15.14.01 16.44 0c.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v3.96c-1.45-.07-2.91-.44-4.19-1.15-.39-.22-.75-.48-1.09-.76-.01 3.44.01 6.88-.03 10.32-.09 1.64-.7 3.26-1.75 4.52-1.68 2.06-4.36 3.2-7 3.09-1.72-.06-3.41-.6-4.82-1.56-2.35-1.57-3.88-4.3-3.88-7.16.02-1.72.57-3.41 1.57-4.81 1.34-1.9 3.48-3.21 5.82-3.48.79-.09 1.59-.05 2.37.1v4.01c-.57-.18-1.2-.23-1.79-.12-1.02.2-1.91.88-2.39 1.8-.33.63-.41 1.38-.29 2.08.26 1.5 1.66 2.72 3.2 2.65 1.06-.02 2.08-.6 2.68-1.46.19-.27.35-.57.43-.91.14-.65.09-1.32.09-1.98V.04c.02-.01.04-.02.06-.02z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="max-w-7xl mx-auto mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-brand-muted">
        &copy; {currentYear} First Up Productions
      </p>
      <p class="text-xs text-brand-muted">
        {t(lang, 'footer.also-for')} <a href="https://firstupweddings.de" class="hover:text-brand-accent transition-colors">First Up Weddings</a>
      </p>
    </div>
  </div>
</footer>
