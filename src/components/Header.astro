---
const navItems = [
  { label: 'Angebot', href: '/angebot' },
  { label: 'Arbeitsweise', href: '/arbeitsweise' },
  { label: 'Über mich', href: '/ueber-mich' },
  { label: 'Kontakt', href: '/kontakt' },
];
const currentPath = Astro.url.pathname;
---
<header class="fixed top-0 left-0 right-0 z-50 bg-brand-black/90 backdrop-blur-md border-b border-white/5">
  <nav class="flex items-center justify-between px-6 md:px-12 lg:px-24 py-5">
    <a href="/" class="flex items-center gap-3 group">
      <img src="/logo.png" alt="First Up Productions" class="h-10 w-auto shrink-0" />
      <span class="font-heading text-base font-semibold tracking-wider uppercase text-brand-light group-hover:text-brand-accent transition-colors">
        First Up Productions
      </span>
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden lg:flex items-center gap-8">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'text-sm font-body tracking-wide transition-colors duration-200',
              currentPath.startsWith(item.href)
                ? 'text-brand-accent'
                : 'text-brand-muted hover:text-brand-light',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden text-brand-light p-2"
      aria-label="Menü öffnen"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-brand-black border-t border-white/5">
    <ul class="flex flex-col px-6 py-6 gap-4">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block text-base font-body py-2 transition-colors',
              currentPath.startsWith(item.href)
                ? 'text-brand-accent'
                : 'text-brand-muted hover:text-brand-light',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>

<!-- Spacer for fixed header -->
<div class="h-[73px]"></div>
