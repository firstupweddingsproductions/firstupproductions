---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Kontakt" description="Lassen Sie uns über Ihr Projekt sprechen. Unverbindlich, persönlich, direkt.">

  <section class="section-padding bg-brand-black pt-32">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Left: Text -->
        <div>
          <h1 class="text-4xl md:text-5xl font-heading mb-6">Lassen Sie uns über Ihr Projekt sprechen.</h1>
          <p class="text-brand-light/60 leading-relaxed mb-10">
            Ob konkretes Projekt, eine erste Idee oder der Wunsch nach einer laufenden Content-Partnerschaft: schreiben Sie mir, und ich melde mich zeitnah bei Ihnen. Unverbindlich, persönlich und direkt.
          </p>

          <div class="space-y-6">
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">E-Mail</h3>
              <a href="mailto:firstaproductions.media@gmail.com" class="text-brand-light/70 hover:text-brand-accent transition-colors">firstaproductions.media@gmail.com</a>
            </div>
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Telefon</h3>
              <a href="tel:+491732118910" class="text-brand-light/70 hover:text-brand-accent transition-colors">+49 173 2118910</a>
            </div>
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Standort</h3>
              <p class="text-brand-light/70">Deutschland</p>
            </div>
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Social Media</h3>
              <div class="flex gap-4 text-brand-light/70">
                <a href="https://www.instagram.com/firstupproductions/" target="_blank" rel="noopener noreferrer" class="hover:text-brand-accent transition-colors">Instagram</a>
                <span>Vimeo</span>
                <a href="https://www.tiktok.com/@firstupproductions" target="_blank" rel="noopener noreferrer" class="hover:text-brand-accent transition-colors">TikTok</a>
              </div>
            </div>
          </div>

          <p class="text-sm text-brand-muted mt-10 italic">Kein ausgearbeitetes Briefing nötig. Ein kurzes Gespräch über Ihr Vorhaben reicht als Startpunkt, alles Weitere klären wir gemeinsam.</p>
        </div>

        <!-- Right: Form -->
        <div class="bg-brand-dark p-8 lg:p-10 border border-white/5">
          <form id="contact-form" class="space-y-6" novalidate>
            <!-- Web3Forms credentials. TODO: replace YOUR_WEB3FORMS_PRODUCTIONS_ACCESS_KEY with the access key from https://web3forms.com after registering with firstaproductions.media@gmail.com. -->
            <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_PRODUCTIONS_ACCESS_KEY" />
            <input type="hidden" name="subject" value="Neue Projektanfrage über First Up Productions" />
            <input type="hidden" name="from_name" value="First Up Productions Website" />
            <!-- Honeypot field (visually hidden but reachable to bots) -->
            <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" aria-hidden="true" />

            <div>
              <label for="name" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Name *</label>
              <input type="text" id="name" name="name" required autocomplete="name" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="email" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">E-Mail *</label>
              <input type="email" id="email" name="email" required autocomplete="email" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="phone" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Telefon</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="Für einen Rückruf" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light placeholder:text-brand-light/20 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="company" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Unternehmen / Organisation</label>
              <input type="text" id="company" name="company" autocomplete="organization" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light placeholder:text-brand-light/20 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="project_type" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Art des Projekts</label>
              <select id="project_type" name="project_type" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light focus:border-brand-accent focus:outline-none transition-colors cursor-pointer">
                <option value="">Bitte wählen</option>
                <option value="Imagefilm">Imagefilm</option>
                <option value="Eventvideo">Eventvideo</option>
                <option value="Interview">Interview</option>
                <option value="Social Media Content / Reels">Social Media Content / Reels</option>
                <option value="Produkt- oder Projektvideo">Produkt- oder Projektvideo</option>
                <option value="Recruiting-Video">Recruiting-Video</option>
                <option value="Sonstiges">Sonstiges</option>
              </select>
            </div>
            <div>
              <label for="timeline" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Gewünschter Zeitraum / Deadline</label>
              <input type="text" id="timeline" name="timeline" placeholder="z. B. Q3 2026 oder ASAP" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light placeholder:text-brand-light/20 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="budget" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Budgetrahmen</label>
              <input type="text" id="budget" name="budget" placeholder="z. B. 5.000 – 10.000 €" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light placeholder:text-brand-light/20 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="message" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Nachricht *</label>
              <textarea id="message" name="message" rows="4" required placeholder="Erzählen Sie kurz von Ihrem Vorhaben — Ziel, Zielgruppe, Format-Ideen, alles hilft." class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light placeholder:text-brand-light/20 focus:border-brand-accent focus:outline-none transition-colors resize-none"></textarea>
            </div>

            <button type="submit" id="contact-submit" class="btn-primary w-full text-center">Nachricht senden</button>

            <p id="contact-status" class="text-sm leading-relaxed hidden" role="status" aria-live="polite"></p>

            <p class="text-xs text-brand-muted leading-relaxed mt-2">
              Mit dem Absenden willigen Sie ein, dass Ihre Angaben zur Bearbeitung Ihrer Anfrage verarbeitet werden. Mehr dazu in der <a href="/datenschutz" class="underline hover:text-brand-accent transition-colors">Datenschutzerklärung</a>.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('contact-status') as HTMLParagraphElement | null;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;

    if (form && status && submitBtn) {
      const originalLabel = submitBtn.textContent ?? 'Nachricht senden';

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        status.classList.remove('hidden', 'text-brand-accent', 'text-red-400');
        status.textContent = '';
        submitBtn.disabled = true;
        submitBtn.textContent = 'Wird gesendet …';

        try {
          const formData = new FormData(form);
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData,
          });
          const json = await response.json();

          if (response.ok && json.success) {
            status.textContent = 'Vielen Dank! Ihre Nachricht ist angekommen. Ich melde mich zeitnah persönlich bei Ihnen.';
            status.classList.remove('hidden');
            status.classList.add('text-brand-accent');
            form.reset();
          } else {
            throw new Error(json.message || 'Senden fehlgeschlagen');
          }
        } catch (error) {
          console.error(error);
          status.textContent = 'Da ist leider etwas schiefgelaufen. Schreiben Sie mir gerne direkt an firstaproductions.media@gmail.com — ich antworte schnell.';
          status.classList.remove('hidden');
          status.classList.add('text-red-400');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = originalLabel;
        }
      });
    }
  </script>

</Layout>
