  <section class="section-padding bg-brand-black pt-32">
    <div class="container-narrow">
      <h1 class="text-4xl md:text-5xl font-heading text-brand-light mb-10">Imprint</h1>

      <p class="text-sm text-brand-muted italic mb-10">
        This is an informational English translation. The legally binding version is the <a href="/impressum" class="underline hover:text-brand-accent transition-colors">German imprint</a>.
      </p>

      <div class="space-y-10 text-brand-light/70 leading-relaxed">

        <div>
          <h2 class="text-xl font-heading text-brand-light mb-3">Information according to § 5 DDG</h2>
          <p>
            First Up Productions<br />
            Project / brand by Adem Kocyigit
          </p>
          <p class="mt-3">
            Adem Kocyigit<br />
            Tiefe Allee 33<br />
            24149 Kiel<br />
            Germany
          </p>
          <p class="mt-3 text-sm text-brand-muted">
            First Up Productions is currently a project / brand by Adem Kocyigit as a natural person. It is not a GmbH, UG, or other registered company.
          </p>
        </div>

        <div>
