---
import Layout from '../../layouts/Layout.astro';
---
<Layout lang="en" title="Contact" description="Let's talk about your project. No commitment, personal, direct.">

  <section class="section-padding bg-brand-black pt-32">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Left: Text -->
        <div>
          <h1 class="text-4xl md:text-5xl font-heading mb-6">Let's talk about your project.</h1>
          <p class="text-brand-light/60 leading-relaxed mb-10">
            Whether it's a concrete project, an early idea, or interest in an ongoing content partnership: write to me and I'll get back to you promptly. No commitment, personal, and direct.
          </p>

          <div class="space-y-6">
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Email</h3>
              <a href="mailto:firstupproductions.media@gmail.com" class="text-brand-light/70 hover:text-brand-accent transition-colors">firstupproductions.media@gmail.com</a>
            </div>
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Phone</h3>
              <a href="tel:+491732118910" class="text-brand-light/70 hover:text-brand-accent transition-colors">+49 173 2118910</a>
            </div>
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Location</h3>
              <p class="text-brand-light/70">Germany</p>
            </div>
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Social media</h3>
              <div class="flex gap-4 text-brand-light/70">
                <a href="https://www.instagram.com/firstupproductions/" target="_blank" rel="noopener noreferrer" class="hover:text-brand-accent transition-colors">Instagram</a>
                <span>Vimeo</span>
                <a href="https://www.tiktok.com/@first.up.productions?_r=1&_t=ZG-96EKANmE53Y" target="_blank" rel="noopener noreferrer" class="hover:text-brand-accent transition-colors">TikTok</a>
              </div>
            </div>
          </div>

          <p class="text-sm text-brand-muted mt-10 italic">No polished briefing required. A short conversation about your project is a perfectly good starting point — we'll figure out the rest together.</p>
        </div>

        <!-- Right: Form -->
        <div class="bg-brand-dark p-8 lg:p-10 border border-white/5">
          <form id="contact-form" class="space-y-6" novalidate>
            <!-- Web3Forms access key for firstupproductions.media@gmail.com -->
            <input type="hidden" name="access_key" value="e16c1d5c-4510-4c74-809c-80b2e06d50c0" />
            <input type="hidden" name="subject" value="New project inquiry via First Up Productions" />
            <input type="hidden" name="from_name" value="First Up Productions Website" />
            <!-- Honeypot field (visually hidden but reachable to bots) -->
            <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" aria-hidden="true" />

            <div>
              <label for="name" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Name *</label>
              <input type="text" id="name" name="name" required autocomplete="name" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="email" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Email *</label>
              <input type="email" id="email" name="email" required autocomplete="email" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="phone" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Phone</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="For a callback" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light placeholder:text-brand-light/20 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="company" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Company / organisation</label>
              <input type="text" id="company" name="company" autocomplete="organization" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light placeholder:text-brand-light/20 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="timeline" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Preferred timeline / deadline</label>
              <input type="text" id="timeline" name="timeline" placeholder="e. g. Q3 2026 or ASAP" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light placeholder:text-brand-light/20 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="budget" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Budget range</label>
              <input type="text" id="budget" name="budget" placeholder="e. g. €5,000 – €10,000" class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light placeholder:text-brand-light/20 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="message" class="block text-xs uppercase tracking-widest text-brand-muted mb-2">Message *</label>
              <textarea id="message" name="message" rows="4" required placeholder="Tell us briefly about your project — goal, audience, format ideas, anything helps." class="w-full bg-brand-black border border-white/10 px-4 py-3 text-sm text-brand-light placeholder:text-brand-light/20 focus:border-brand-accent focus:outline-none transition-colors resize-none"></textarea>
            </div>

            <button type="submit" id="contact-submit" class="btn-primary w-full text-center">Send message</button>

            <p id="contact-status" class="text-sm leading-relaxed hidden" role="status" aria-live="polite"></p>

            <p class="text-xs text-brand-muted leading-relaxed mt-2">
              By submitting, you agree that your information will be processed to handle your inquiry. More in the <a href="/en/privacy" class="underline hover:text-brand-accent transition-colors">privacy policy</a>.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('contact-status') as HTMLParagraphElement | null;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;

    if (form && status && submitBtn) {
      const originalLabel = submitBtn.textContent ?? 'Send message';

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        status.classList.remove('hidden', 'text-brand-accent', 'text-red-400');
        status.textContent = '';
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending …';

        try {
          const formData = new FormData(form);
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData,
          });
          const json = await response.json();

          if (response.ok && json.success) {
            status.textContent = "Thank you! Your message has arrived. I'll get back to you promptly and personally.";
            status.classList.remove('hidden');
            status.classList.add('text-brand-accent');
            form.reset();
          } else {
            throw new Error(json.message || 'Submission failed');
          }
        } catch (error) {
          console.error(error);
          status.textContent = 'Something went wrong. Please write to me directly at firstupproductions.media@gmail.com — I reply quickly.';
          status.classList.remove('hidden');
          status.classList.add('text-red-400');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = originalLabel;
        }
      });
    }
  </script>

</Layout>
